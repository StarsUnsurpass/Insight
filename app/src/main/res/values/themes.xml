<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- 基础主题 -->
    <style name="Theme.Insight" parent="android:Theme.Material.NoActionBar">
        <item name="android:windowBackground">@android:color/white</item>
    </style>

    <!-- 启动页主题 -->
    <style name="Theme.Insight.Launch" parent="Theme.SplashScreen">
        <!-- 启动页背景色 -->
        <item name="windowSplashScreenBackground">@android:color/white</item>
        <!-- 启动图标 (API 31+)，我们在这里设为透明，因为 MainActivity.kt 中会自定义动画 -->
        <item name="windowSplashScreenAnimatedIcon">@android:color/transparent</item>
        <!-- 启动完成后切换到的正式主题 -->
        <item name="postSplashScreenTheme">@style/Theme.Insight</item>
    </style>
</resources>

